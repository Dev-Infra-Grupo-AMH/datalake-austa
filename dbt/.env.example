# Copie para .env na pasta dbt/ e preencha os valores.
#   cp .env.example .env
# O arquivo .env não deve ser commitado (ver .gitignore na raiz do repositório).

# Hostname do Spark Thrift / Kyuubi (ex.: kyuubi.sua-rede.internal)
SPARK_THRIFT_HOST=

# Porta Thrift (padrão comum: 10009)
SPARK_THRIFT_PORT=10009

# Credenciais LDAP usadas na autenticação Thrift
SPARK_THRIFT_USER=
SPARK_THRIFT_PASSWORD=
