# .env.example — Lakehouse Austa
# Copie para .env e preencha com os valores reais.
# NUNCA commite o .env preenchido.

# ── AWS ───────────────────────────────────────────────
AWS_PROFILE=austa
AWS_REGION=sa-east-1

# ── Kyuubi / Spark Thrift (dbt-spark) ─────────────────
SPARK_THRIFT_HOST=
SPARK_THRIFT_PORT=10009
SPARK_THRIFT_USER=
SPARK_THRIFT_PASSWORD=

# ── Airflow ───────────────────────────────────────────
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=

# ── dbt ───────────────────────────────────────────────
DBT_PROFILES_DIR=./dbt
DBT_TARGET=dev

# ── Debezium / Kafka ──────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=
DEBEZIUM_HOST=
DEBEZIUM_PORT=8083

# ── S3 ────────────────────────────────────────────────
S3_BUCKET=austa-lakehouse-prod-data-lake-169446931765
S3_PREFIX_RAW=raw/raw-tasy/
